{
	"compilerOptions": {
		"baseUrl": ".",
		"inlineSourceMap": true,
		"inlineSources": true,
		"module": "ESNext",
		"target": "ES2020",
		"allowJs": true,
		"moduleResolution": "bundler",
		"isolatedModules": true,
		"strict": true,
		"noImplicitReturns": true,
		"noFallthroughCasesInSwitch": true,
		"lib": ["DOM", "ES2020"]
	},
	"include": ["src/**/*.ts", "src/**/*.d.ts", "src/**/*.d.mts"]
}
